{
  "settings": {
    "analysis": {
      "analyzer": {
        "korean": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["cjk_width", "lowercase", "cjk_bigram"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "title":   { "type": "text", "analyzer": "korean", "fields": { "en": { "type": "text", "analyzer": "english" } } },
      "summary": { "type": "text", "analyzer": "korean", "fields": { "en": { "type": "text", "analyzer": "english" } } },
      "problem": { "type": "text", "analyzer": "korean", "fields": { "en": { "type": "text", "analyzer": "english" } } },
      "idea":    { "type": "text", "analyzer": "korean", "fields": { "en": { "type": "text", "analyzer": "english" } } },
      "tags":         { "type": "keyword", "fields": { "text": { "type": "text", "analyzer": "standard" } } },
      "category":     { "type": "keyword" },
      "card_type":    { "type": "keyword" },
      "difficulty":   { "type": "keyword" },
      "published_at": { "type": "date" },
      "like_count":   { "type": "integer" }
    }
  }
}
