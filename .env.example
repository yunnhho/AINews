# ─────────────────────────────────────────
# AI Pulse — 환경변수 예시
# 실제 값을 채운 뒤 .env 로 복사하여 사용
# ─────────────────────────────────────────

# ── 애플리케이션 ──────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────
POSTGRES_USER=aipulse
POSTGRES_PASSWORD=aipulse
POSTGRES_DB=aipulse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://aipulse:aipulse@postgres:5432/aipulse

# ── Redis ─────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Elasticsearch ────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ── Claude API ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub ───────────────────────────────
GITHUB_TOKEN=ghp_...

# ── OAuth — Google ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

# ── OAuth — GitHub ───────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/v1/auth/github/callback

# ── OAuth — Kakao ─────────────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/v1/auth/kakao/callback

# ── Expo Push Notification ────────────────
EXPO_ACCESS_TOKEN=

# ── JWT ───────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Celery ───────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── sentence-transformers ────────────────
# 워커 컨테이너 안에서 자동 다운로드
SENTENCE_TRANSFORMER_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ── Admin ────────────────────────────────
# 관리자 user ID (콤마 구분, 예: 1,2,3)
ADMIN_USER_IDS=
MONTHLY_BUDGET_USD=100.0

# ── 알림 (Slack + 이메일) ─────────────────
ALERT_SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── IMAP (D-2 뉴스레터 이메일 수집) ──────────
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# ── 프론트엔드 ────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
