# ─────────────────────────────────────────
# AI Pulse — 환경변수 예시
# 실제 값을 채운 뒤 .env 로 복사하여 사용
# ─────────────────────────────────────────

# ── 애플리케이션 ──────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000
# 보안: 운영(production) TrustedHost 허용 호스트(콤마 구분), IP당 분당 요청 상한
ALLOWED_HOSTS=localhost,127.0.0.1,.aipulse.kr
RATELIMIT_PER_MINUTE=300
# 인증 경로(/v1/auth) 전용 강한 레이트리밋 (토큰/코드 brute-force 방어)
AUTH_RATELIMIT_PER_MINUTE=10
# 앞단 신뢰 프록시(LB/리버스프록시) 홉 수. 직접 노출이면 0(XFF 무시). 프록시 1대면 1.
TRUSTED_PROXY_COUNT=0

# ── 인증 쿠키 (웹) ────────────────────────
# 운영(HTTPS)에서는 COOKIE_SECURE=true 필수, COOKIE_DOMAIN은 프론트/백 공통 상위도메인.
COOKIE_DOMAIN=                 # 예: .aipulse.kr (운영). 비우면 호스트 전용
COOKIE_SECURE=false            # 운영(HTTPS)에서 true
COOKIE_SAMESITE=lax            # 동일 사이트(서브도메인)면 lax

# ── PostgreSQL ────────────────────────────
POSTGRES_USER=aipulse
POSTGRES_PASSWORD=aipulse
POSTGRES_DB=aipulse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://aipulse:aipulse@postgres:5432/aipulse

# ── Redis ─────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Elasticsearch ────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ── Claude API ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub ───────────────────────────────
GITHUB_TOKEN=ghp_...

# ── OAuth — Google ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

# ── OAuth — GitHub ───────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/v1/auth/github/callback

# ── OAuth — Kakao ─────────────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/v1/auth/kakao/callback

# ── Expo Push Notification ────────────────
EXPO_ACCESS_TOKEN=

# ── JWT ───────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Celery ───────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── sentence-transformers ────────────────
# 워커 컨테이너 안에서 자동 다운로드
SENTENCE_TRANSFORMER_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ── Admin ────────────────────────────────
# 관리자 user ID (콤마 구분, 예: 1,2,3)
ADMIN_USER_IDS=
# 월 API 예산(USD) — admin 대시보드 표시 + 파이프라인 하드 캡(도달 시 배치 AI 처리 중단)
MONTHLY_BUDGET_USD=100.0

# ── 알림 (Slack + 이메일) ─────────────────
ALERT_SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── IMAP (D-2 뉴스레터 이메일 수집) ──────────
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# ── 프론트엔드 ────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_SITE_URL=https://aipulse.kr
NEXT_PUBLIC_KAKAO_JS_KEY=
